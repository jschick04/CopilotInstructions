#!/usr/bin/env sh
# Pre-commit hook: enforce HIGH-TIER-SLUGS.md stays in sync with pattern-catalog.md.
#
# Triggers when EITHER pattern-catalog.md OR HIGH-TIER-SLUGS.md is staged.
# Prefers pwsh (full canonical generator); falls back to bash twin
# (scripts/sync-critical-rules.sh) when pwsh is unavailable.
# Bypassable via `git commit --no-verify`; CI catalog-sync-check.yml is the backstop.
#
# See panel-policy.md §"Catalog-edit + ack-sync invariant" for design rationale.

set -e

# === Amend sign-off gate ===========================================================
# A history rewrite (git commit --amend, signalled by PANEL_GATE_AMEND=1) requires a fresh,
# tree-bound user sign-off recorded after an explicit ask_user. Identity-gated in the script.
if [ "${PANEL_GATE_AMEND:-0}" = "1" ] && command -v pwsh >/dev/null 2>&1 && [ -f scripts/check-signoff.ps1 ]; then
    if ! pwsh -NoProfile -File scripts/check-signoff.ps1 -Mode amend; then
        echo "ERROR: this amend rewrites history but has no fresh user sign-off marker." >&2
        echo "       Get explicit sign-off (ask_user) and record amend_approved before amending." >&2
        exit 1
    fi
fi

# === Post-code-change panel LEDGER gate ============================================
# Adoption-gated on the panel checker script, so enforcement cannot be disabled by
# deleting the receipt. On a non-adopted repo this no-ops.
# Placed BEFORE the catalog early-exit so it runs on every commit, not just catalog edits.
# Bypassable via `git commit --no-verify` (which AGENTS.md §0 itself gates); CI pr-gate-check
# is the PR backstop. The panel ledger is required only for commits whose staged diff touches
# code/governance paths (the checker re-derives that; pure-docs commits no-op).
if git cat-file -e HEAD:scripts/check-post-code-change.ps1 2>/dev/null || [ -f scripts/check-post-code-change.ps1 ]; then
    if [ ! -f scripts/check-post-code-change.ps1 ]; then
        echo "ERROR: scripts/check-post-code-change.ps1 is committed (panel gate adopted) but absent from the working tree." >&2
        echo "       Refusing to commit removal/disable of the enforcement without verification (fail-closed)." >&2
        exit 1
    fi
    if command -v pwsh >/dev/null 2>&1; then
        if ! pwsh -NoProfile -File scripts/check-post-code-change.ps1 -StagedMode -WorktreeReceipt; then
            echo "" >&2
            echo "ERROR: the staged change is panel-required but its post-code-change LEDGER receipt is missing/stale/invalid." >&2
            echo "       Run the post-code-change reviewer panel, write the LEDGER receipt to" >&2
            echo "       .github/pr-quality-gate/audits/post-code-change-last.md (gitignored; the post-commit hook records it as a note)." >&2
            exit 1
        fi
    else
        echo "ERROR: pwsh not available; cannot verify the post-code-change panel LEDGER." >&2
        echo "       Install PowerShell 7+ (pwsh). Bypass at your own risk: git commit --no-verify (CI verifies PRs)." >&2
        exit 1
    fi
fi

# === Structural conformance (Layer-A fast-fail; CI is the authoritative gate) =======
# Every Added/Copied/Renamed staged path must match the structure manifest, else block -
# prevents cross-session folder divergence. Local fast-fail; CI runs it base-pinned (non-skippable).
if command -v pwsh >/dev/null 2>&1 && [ -f scripts/check-structural-conformance.ps1 ]; then
    if ! pwsh -NoProfile -File scripts/check-structural-conformance.ps1; then
        echo "ERROR: a staged path does not conform to the structure manifest (see above)." >&2
        echo "       Place the file to match an existing pattern, or get sign-off to evolve the manifest." >&2
        exit 1
    fi
fi


if ! git diff --cached --name-only | grep -qE '\.github/pr-quality-gate/(pattern-catalog|HIGH-TIER-SLUGS)\.md$'; then
    exit 0
fi

if ! git ls-files --error-unmatch .github/pr-quality-gate/HIGH-TIER-SLUGS.md >/dev/null 2>&1; then
    echo "ERROR: .github/pr-quality-gate/HIGH-TIER-SLUGS.md is missing from the index." >&2
    echo "       Restore it via: pwsh -File scripts/sync-critical-rules.ps1" >&2
    echo "       Then stage it: git add .github/pr-quality-gate/HIGH-TIER-SLUGS.md" >&2
    exit 1
fi

if command -v pwsh >/dev/null 2>&1; then
    if ! pwsh -NoProfile -File scripts/sync-critical-rules.ps1 -Verify -StagedMode; then
        echo "" >&2
        echo "ERROR: HIGH-TIER-SLUGS.md is out of sync with the staged pattern-catalog.md." >&2
        echo "       Run: pwsh -File scripts/sync-critical-rules.ps1" >&2
        echo "       Then: git add .github/pr-quality-gate/HIGH-TIER-SLUGS.md" >&2
        exit 1
    fi
elif command -v bash >/dev/null 2>&1; then
    if ! bash scripts/sync-critical-rules.sh -Verify -StagedMode; then
        echo "" >&2
        echo "ERROR: HIGH-TIER-SLUGS.md is out of sync (verified via bash twin)." >&2
        echo "       Run: bash scripts/sync-critical-rules.sh" >&2
        echo "       Then: git add .github/pr-quality-gate/HIGH-TIER-SLUGS.md" >&2
        exit 1
    fi
else
    echo "ERROR: neither pwsh nor bash is available; cannot verify ack-sync." >&2
    echo "       Install PowerShell 7+ (pwsh) or bash to enable the pre-commit hook." >&2
    echo "       Bypass at your own risk: git commit --no-verify (CI will still verify)." >&2
    exit 1
fi
